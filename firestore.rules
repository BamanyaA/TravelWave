rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'email', 'role']) &&
             data.keys().size() >= 4 && data.keys().size() <= 5 &&
             data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             data.role in ['user', 'admin'] &&
             // Prevent self-elevation if not already an admin, EXCEPT for the known owner email during initial creation
             (data.role == 'user' || isAdmin() || (data.email == 'bamanejigu112@gmail.com' && !exists(/databases/$(database)/documents/users/$(request.auth.uid))));
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        // Prevent changing immutable fields
        incoming().uid == existing().uid &&
        (incoming().role == existing().role || isAdmin())
      );
    }

    // Application Validation
    function isValidApplication(data) {
      return data.keys().hasAll(['userId', 'fullName', 'purpose', 'destination', 'status', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.purpose in ['Tourism', 'Work', 'Study', 'Business'] &&
             data.destination is string && data.destination.size() <= 100 &&
             data.status in ['pending', 'processing', 'approved', 'rejected'] &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    match /applications/{appId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
      
      allow create: if isSignedIn() && isValidId(appId) && isValidApplication(incoming()) &&
                      incoming().status == 'pending' &&
                      // Allow for small clock drift (within 1 minute)
                      incoming().createdAt >= request.time.toMillis() - 60000 &&
                      incoming().createdAt <= request.time.toMillis() + 60000 &&
                      incoming().updatedAt == incoming().createdAt;

      allow update: if isSignedIn() && (isAdmin() || isOwner(existing().userId)) &&
                      isValidApplication(incoming()) && (
                        // Admin action: Change status
                        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                        // Owner action: Edit details (only if pending)
                        (isOwner(existing().userId) && existing().status == 'pending' &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'purpose', 'destination', 'updatedAt']))
                      ) &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt >= request.time.toMillis() - 60000 &&
                      incoming().updatedAt <= request.time.toMillis() + 60000;
    }

    // Payment Validation
    function isValidPayment(data) {
      return data.keys().hasAll(['applicationId', 'userId', 'amount', 'receiptUrl', 'status', 'createdAt', 'bankName', 'accountNumber']) &&
             data.userId == request.auth.uid &&
             data.applicationId is string &&
             data.amount is number &&
             data.receiptUrl is string &&
             data.status in ['pending', 'confirmed'] &&
             data.createdAt is number &&
             data.bankName is string &&
             data.accountNumber is string;
    }

    match /payments/{paymentId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isValidId(paymentId) && isValidPayment(incoming()) &&
                      incoming().status == 'pending' &&
                      incoming().createdAt >= request.time.toMillis() - 300000 &&
                      incoming().createdAt <= request.time.toMillis() + 300000 &&
                      // Verify application ownership
                      get(/databases/$(database)/documents/applications/$(incoming().applicationId)).data.userId == request.auth.uid;

      allow update: if isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      incoming().status == 'confirmed';
    }

    match /admins/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isOwner(userId) && request.auth.token.email == 'bamanejigu112@gmail.com';
      allow write: if false; 
    }
  }
}
